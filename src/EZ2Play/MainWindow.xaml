<ui:FluentWindow x:Class="EZ2Play.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:app="clr-namespace:EZ2Play.App"
                 Title="EZ2Play Game Launcher"
                 ExtendsContentIntoTitleBar="True"
                 WindowState="Maximized"
                 WindowStyle="None"
                 Topmost="False"
                 ShowInTaskbar="True"
                 Cursor="None"
                 SnapsToDevicePixels="True"
                 UseLayoutRounding="True"
                 Background="Transparent"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize"
                 MinWidth="1024"
                 MinHeight="576">
    

    <!-- Window Background {DynamicResource LayerOnAcrylicFillColorDefaultBrush} -->
    <Border Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}" Margin="0">

        <Grid x:Name="RootGrid"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">

            <!-- Outer Background -->
            <Image x:Name="BackgroundImage"
                Stretch="UniformToFill"
                Opacity="0"
                Visibility="Collapsed"
                RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- ParticlesCanvas -->
            <app:ParticlesCanvas x:Name="particles" />

            <!-- SplashOverlay -->
            <Grid x:Name="SplashOverlay" Visibility="Hidden"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="Transparent" IsHitTestVisible="True">

                <Image x:Name="SplashLogo"
                       MaxHeight="{DynamicResource {x:Static app:UiScaleKeys.SplashLogoMaxHeight}}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <!-- NoShortcutsMessage -->
            <TextBlock x:Name="NoShortcutsMessage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       TextAlignment="Center"
                       Margin="{DynamicResource {x:Static app:UiScaleKeys.NoShortcutsMargin}}"
                       FontSize="{DynamicResource {x:Static app:UiScaleKeys.NoShortcutsFontSize}}"
                       FontWeight="ExtraLight"
                       Visibility="Collapsed"
                       Style="{StaticResource HintTextStyle}">
                <Run x:Name="NoShortcutsMessageTop"/>
                <LineBreak/><LineBreak/>
                <Run x:Name="NoShortcutsMessageBottom"/>
            </TextBlock>

            <!-- ExitOverlay -->
            <Border x:Name="ExitOverlay" Visibility="Hidden"/>
            <TextBlock x:Name="ExitMessageText"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="{DynamicResource {x:Static app:UiScaleKeys.ExitMessageFontSize}}"
                       FontWeight="ExtraLight"
                       Visibility="Hidden"
                       Panel.ZIndex="11">
                <Run Text="Assembled by"/>
                <Run Text="{x:Static app:AppInfo.Company}"/>
            </TextBlock>

            <!-- Overlay -->
            <ContentControl x:Name="OverlayHost" Panel.ZIndex="100"/>

            <!-- <Border Panel.ZIndex="100"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="40"
                                    ShadowDepth="0"
                                    Opacity="0.35"/>
                </Border.Effect>

                <ContentControl x:Name="OverlayHost"/>
            </Border> -->

            <!-- MainScreenGrid -->
            <Grid x:Name="MainScreenGrid" Visibility="Collapsed" Panel.ZIndex="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="30*"/>
                    <RowDefinition Height="20*"/>
                </Grid.RowDefinitions>

                <!-- TopPanel -->
                <Grid x:Name="TopPanel" Grid.Row="0"
                      Margin="{DynamicResource {x:Static app:UiScaleKeys.TopPanelMargin}}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="05*"/> <!-- 0 Offset -->
                        <ColumnDefinition Width="30*"/> <!-- 1 Tabs (Gamelist/LastPlayed) -->
                        <ColumnDefinition Width="50*"/> <!-- 2 NotificationPanel -->
                        <ColumnDefinition Width="05*"/> <!-- 3 UserAvatar -->
                        <ColumnDefinition Width="05*"/> <!-- 4 Time -->
                        <ColumnDefinition Width="05*"/> <!-- 5 Offset -->
                    </Grid.ColumnDefinitions>

                    <!-- Tabs -->
                    <StackPanel Orientation="Horizontal" Grid.Column="1">
                        <TextBlock x:Name="TabGamelistText"
                                Opacity="1"
                                FontSize="{DynamicResource {x:Static app:UiScaleKeys.TopInfoPrimalyFontSize}}"
                                FontWeight="ExtraBold"/>
                        <TextBlock x:Name="TabLastPlayedText"
                                Margin="{DynamicResource {x:Static app:UiScaleKeys.TopInfoTabsMargin}}"
                                Opacity="0.5"
                                FontSize="{DynamicResource {x:Static app:UiScaleKeys.TopInfoSecondaryFontSize}}"/>
                    </StackPanel>

                    <!-- NotificationPanel -->
                    <Border x:Name="NotificationPanel"
                            Grid.Column="2"
                            Visibility="Collapsed"
                            Style="{StaticResource BasicCardStyle}"
                            CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.BaseCornerRadius}}"
                            Height="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelHeight}}"
                            Padding="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelPadding}}"
                            Margin="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelOuterMargin}}"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock  FontSize="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelIconSize}}"
                                        VerticalAlignment="Center" 
                                        Margin="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelMargin}}"
                                        FontFamily="Xbox Fluent">&#xE686;</TextBlock>
                            <TextBlock  x:Name="NotificationText"
                                        Style="{StaticResource BasicCardTextStyle}"
                                        MaxWidth="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelMaxWidth}}"
                                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.NotificationPanelFontSize}}"
                                        VerticalAlignment="Center"
                                        TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- UserAvatar -->
                    <Image  x:Name="UserAvatar" Grid.Column="3"
                            Width="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Height="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Stretch="UniformToFill"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>

                    <!-- Time -->
                    <TextBlock x:Name="TimeLabelText" Grid.Column="4"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource {x:Static app:UiScaleKeys.TopInfoPrimalyFontSize}}"
                               FontWeight="SemiBold"/>

                </Grid>

                <!-- ItemsListBox -->
                <Grid x:Name="CarouselWrapper" Grid.Row="1" ClipToBounds="True">
                    <ListBox x:Name="ItemsListBox" 
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            BorderThickness="0"
                            Padding="0"
                            ClipToBounds="False"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Disabled"
                            SelectionChanged="ItemsListBox_SelectionChanged"
                            ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                            VirtualizingPanel.IsVirtualizing="False">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <app:CarouselPanel/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <app:CarouselItem IsSelected="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- SelectedGameTitle -->
                <Grid Grid.Row="2">
                    <StackPanel Orientation="Vertical"
                                Margin="{DynamicResource {x:Static app:UiScaleKeys.GameTitleMargin}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- TextBlock -->
                            <TextBlock x:Name="SelectedGameTitle"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SelectedGameTitleFontSize}}"
                                    FontWeight="Medium"
                                    TextAlignment="Left"
                                    TextWrapping="Wrap"
                                    HorizontalAlignment="Stretch">
                            </TextBlock>

                        </StackPanel>

                        <!-- GameSourceCard -->
                        <StackPanel Orientation="Horizontal" 
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.SourceCardMargin}}">
                            <Border x:Name="GameSourceCard"
                                    Style="{StaticResource BasicCardStyle}"
                                    CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.BaseCornerRadius}}"
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.SourceCardWidth}}"
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.SourceCardHeight}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left">

                                <TextBlock Text="{Binding ElementName=ItemsListBox, Path=SelectedItem.SourceType}"
                                        Style="{StaticResource BasicCardTextStyle}"
                                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SourceCardFontSize}}"
                                        FontWeight="Bold"
                                        TextAlignment="Center"/>
                            </Border>

                            <!-- GameCounterCard -->
                            <Border x:Name="GameCounterCard"
                                    Background="{DynamicResource ControlFillColorInputActiveBrush}"
                                    BorderBrush="{DynamicResource LayerFillColorAltBrush}"
                                    BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.CounterCardThickness}}"
                                    Padding="{DynamicResource {x:Static app:UiScaleKeys.CounterCardPadding}}"
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.CounterCardMargin}}"
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.CounterCardHeight}}"
                                    CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.BaseCornerRadius}}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock  FontSize="{DynamicResource {x:Static app:UiScaleKeys.CounterCardIconSize}}"
                                                VerticalAlignment="Center" 
                                                Margin="{DynamicResource {x:Static app:UiScaleKeys.CounterCardIconMargin}}"
                                                FontFamily="Xbox Fluent">&#xE35F;</TextBlock><!-- E7FB -->
                                    
                                    <TextBlock  x:Name="GameCounterText"
                                                FontSize="{DynamicResource {x:Static app:UiScaleKeys.CounterCardFontSize}}"
                                                FontWeight="ExtraBold"
                                                TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- LoadingProgress -->
                            <ui:ProgressRing x:Name="LoadingProgress" 
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.CounterCardMargin}}"
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.LoadingProgressScale}}" 
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.LoadingProgressScale}}"
                                    IsIndeterminate="True"
                                    Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- BottomPanel -->
            <app:HintPanel x:Name="BottomPanel"
            Grid.Row="3"
            Panel.ZIndex="105"
            Mode="Main"
            Device="Keyboard"
            Visibility="Collapsed"
            Margin="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelMargin}}"
            CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.BaseCornerRadius}}"
            Height="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelHeight}}"
            Padding="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelPadding}}" />

        </Grid>
    </Border>
</ui:FluentWindow>
