<ui:FluentWindow x:Class="EZ2Play.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:app="clr-namespace:EZ2Play.App"
                 Title="EZ2Play Game Launcher"
                 ExtendsContentIntoTitleBar="True"
                 WindowState="Maximized"
                 WindowStyle="None"
                 Topmost="False"
                 ShowInTaskbar="True"
                 Cursor="None"
                 SnapsToDevicePixels="True"
                 UseLayoutRounding="True"
                 Background="Transparent"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize"
                 MinWidth="1024"
                 MinHeight="576">

    <!-- Window Background {DynamicResource LayerOnAcrylicFillColorDefaultBrush} -->
    <Border Background="{DynamicResource LayerOnAcrylicFillColorDefaultBrush}" Margin="0">

        <Grid x:Name="RootGrid"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">

            <!-- Outer Background -->
            <Image x:Name="BackgroundImage"
                Stretch="UniformToFill"
                Opacity="0"
                Visibility="Collapsed"
                RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- ParticlesCanvas -->
            <app:ParticlesCanvas x:Name="particles" />

            <!-- SplashOverlay -->
            <Grid x:Name="SplashOverlay" Visibility="Hidden"
                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Background="Transparent" IsHitTestVisible="True">

                <Image x:Name="SplashLogo"
                       MaxHeight="{DynamicResource {x:Static app:UiScaleKeys.SplashLogoMaxHeight}}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Opacity="0" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Grid>

            <!-- NoShortcutsMessage -->
            <TextBlock x:Name="NoShortcutsMessage"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom"
                       TextAlignment="Center"
                       Margin="{DynamicResource {x:Static app:UiScaleKeys.NoShortcutsMargin}}"
                       FontSize="{DynamicResource {x:Static app:UiScaleKeys.NoShortcutsFontSize}}"
                       FontWeight="ExtraLight"
                       Visibility="Collapsed"
                       Style="{StaticResource HintTextStyle}">
                <Run x:Name="NoShortcutsMessage1"/>
                <LineBreak/><LineBreak/>
                <Run x:Name="NoShortcutsMessage2"/>
            </TextBlock>

            <!-- ExitOverlay -->
            <Border x:Name="ExitOverlay" Visibility="Hidden"/>
            <TextBlock x:Name="ExitMessageText"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="{DynamicResource {x:Static app:UiScaleKeys.ExitMessageFontSize}}"
                       FontWeight="ExtraLight"
                       Visibility="Hidden"
                       Panel.ZIndex="11">
                <Run x:Name="ExitMessageRun"/>
                <Run x:Name="CompanyNameRun" Text=""/>
            </TextBlock>

            <!-- VersionLabel -->
            <TextBlock  x:Name="VersionLabel"
                        Visibility="Hidden"
                        Grid.Row="3"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Foreground="{DynamicResource TextFillColorDisabledBrush}"
                        Margin="{DynamicResource {x:Static app:UiScaleKeys.VersionLabelMargin}}"
                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.VersionLabelFontSize}}"
                        TextAlignment="Right">
                <Run Text="v"/><Run Text="{x:Static app:AppInfo.Version}"/>
            </TextBlock>

            <!-- MainScreenGrid -->
            <Grid x:Name="MainScreenGrid" Visibility="Collapsed" Panel.ZIndex="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="15*"/>
                    <RowDefinition Height="35*"/>
                    <RowDefinition Height="40*"/>
                    <RowDefinition Height="20*"/>
                </Grid.RowDefinitions>

                <!-- TopInfoPanel -->
                <Grid x:Name="TopInfoPanel" Grid.Row="0"
                      Margin="{DynamicResource {x:Static app:UiScaleKeys.TopInfoPanelMargin}}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="05*"/> <!-- 0 Offset -->
                        <ColumnDefinition Width="04*"/> <!-- 1 AppLogo -->
                        <ColumnDefinition Width="16*"/> <!-- 2 AppName -->
                        <ColumnDefinition Width="50*"/> <!-- 3 Blank -->
                        <ColumnDefinition Width="16*"/> <!-- 4 Time -->
                        <ColumnDefinition Width="04*"/> <!-- 5 UserAvatar -->
                        <ColumnDefinition Width="05*"/> <!-- 6 Offset -->
                    </Grid.ColumnDefinitions>

                    <!-- AppLogo -->
                    <Image  Grid.Column="1"
                            Source="/Assets/logo.png"
                            Width="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Height="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Stretch="UniformToFill"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"/>

                    <!-- AppName -->
                    <TextBlock  x:Name="TopLeftAppNameText" Grid.Column="2"
                                Text="{x:Static app:AppInfo.Name}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                FontSize="{DynamicResource {x:Static app:UiScaleKeys.TopInfoFontSize}}"
                                FontWeight="ExtraBold"/>

                    <!-- Time -->
                    <TextBlock x:Name="TopRightTimeText" Grid.Column="4"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               FontSize="{DynamicResource {x:Static app:UiScaleKeys.TopInfoFontSize}}"
                               FontWeight="Light"/>

                    <!-- UserAvatar -->
                    <Image  x:Name="UserAvatar" Grid.Column="5"
                            Width="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Height="{DynamicResource {x:Static app:UiScaleKeys.UserAvatarSize}}"
                            Stretch="UniformToFill"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"/>

                </Grid>

                <!-- ItemsListBox -->
                <ListBox x:Name="ItemsListBox" Grid.Row="1"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         BorderThickness="0"
                         Padding="0"
                         ClipToBounds="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionChanged="ItemsListBox_SelectionChanged"
                         ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                         VirtualizingPanel.IsVirtualizing="False">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <app:CarouselPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <app:CarouselItem IsSelected="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- SelectedGameTitle -->
                <Grid Grid.Row="2">
                    <StackPanel Orientation="Vertical"
                                Margin="{DynamicResource {x:Static app:UiScaleKeys.GameTitleMargin}}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <!-- TextBlock -->
                            <TextBlock x:Name="SelectedGameTitle"
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SelectedGameTitleFontSize}}"
                                    FontWeight="Medium"
                                    TextAlignment="Left"
                                    TextWrapping="Wrap"
                                    HorizontalAlignment="Stretch">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="10" 
                                                    ShadowDepth="2" 
                                                    Opacity="0.5" 
                                                    Color="Black"/>
                                </TextBlock.Effect>
                            </TextBlock>

                            <!-- LoadingProgress -->
                            <ui:ProgressRing x:Name="LoadingProgress" 
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.HintBlockMargin}}"
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.LoadingProgressScale}}" 
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.LoadingProgressScale}}"
                                    IsIndeterminate="True"
                                    Visibility="Collapsed"/>

                        </StackPanel>

                        <!-- GameSourceCard -->
                        <Border x:Name="GameSourceCard"
                                Style="{StaticResource GameSourceCardStyle}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ElementName=ItemsListBox, Path=SelectedItem.SourceType}"
                                       Style="{StaticResource GameSourceTextStyle}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- BottomPanel -->
                <Border x:Name="BottomPanel" Tag="BottomPanel" Grid.Row="3"
                        Style="{StaticResource CardGlassStyle}"
                        BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelBorderThickness}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelCornerRadius}}"
                        Height="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelHeight}}"
                        Padding="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelPadding}}">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource {x:Static app:UiScaleKeys.HintBlockMargin}}">
                                <Viewbox x:Name="LaunchIconXinput" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightGamepad}}" Stretch="Uniform" Visibility="Collapsed" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource ButtonA}"/>
                                </Viewbox>
                                <Viewbox x:Name="LaunchIconKeyboard" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightKeyboard}}" Stretch="Uniform" Visibility="Visible" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource KeyEnter}"/>
                                </Viewbox>
                                <TextBlock x:Name="LaunchText" Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource {x:Static app:UiScaleKeys.HintBlockMargin}}">
                                <Viewbox x:Name="ExitIconGamepad" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightGamepad}}" Stretch="Uniform" Visibility="Collapsed" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource ButtonB}"/>
                                </Viewbox>
                                <Viewbox x:Name="ExitIconKeyboard" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightKeyboard}}" Stretch="Uniform" Visibility="Visible" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource KeyEscape}"/>
                                </Viewbox>
                                <TextBlock x:Name="ExitText" Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="{DynamicResource {x:Static app:UiScaleKeys.HintBlockMargin}}">
                                <Viewbox x:Name="ScreenSwapIconGamepad" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightGamepad}}" Stretch="Uniform" Visibility="Collapsed" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource ButtonX}"/>
                                </Viewbox>
                                <Viewbox x:Name="ScreenSwapIconKeyboard" Height="{DynamicResource {x:Static app:UiScaleKeys.HintIconHeightKeyboard}}" Stretch="Uniform" Visibility="Visible" VerticalAlignment="Center">
                                    <ContentPresenter Content="{StaticResource KeyX}"/>
                                </Viewbox>
                                <TextBlock x:Name="ScreenSwapText" Style="{StaticResource HintTextStyle}"/>
                            </StackPanel>
                        </StackPanel>

                </Border>

                <!-- SystemMessage -->
                <Border x:Name="SystemMessage"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Style="{StaticResource CardGlassStyle}"
                        BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.BottomPanelBorderThickness}}"
                        CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageCornerRadius}}"
                        Height="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageHeight}}"
                        Padding="{DynamicResource {x:Static app:UiScaleKeys.SystemMessagePadding}}"
                        Margin="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageOuterMargin}}"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon  Symbol="Info12" Filled="True" 
                                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageIconSize}}"
                                        VerticalAlignment="Center" 
                                        Margin="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageMargin}}"/>
                        <TextBlock  x:Name="SystemMessageText"
                                    MaxWidth="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageMaxWidth}}"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SystemMessageFontSize}}"
                                    VerticalAlignment="Center"
                                    TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </Grid>

        </Grid>
    </Border>
</ui:FluentWindow>
