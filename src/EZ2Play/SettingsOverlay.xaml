<UserControl x:Class="EZ2Play.App.SettingsOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:EZ2Play.App"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{DynamicResource SmokeFillColorDefaultBrush}">
    
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource SolidBackgroundFillColorQuarternaryBrush}"
            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
            BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayThickness}}"
            CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayCornerRadius}}"
            Width="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayWidth}}" 
            Height="Auto"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="85*"/>
                <RowDefinition Height="15*"/>
            </Grid.RowDefinitions>

            <!-- ExitConfirmText -->
            <TextBlock x:Name="ExitConfirmText"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelFontSize}}"
                        HorizontalAlignment="Center"
                        Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayItemPadding}}"/>

            <ListBox x:Name="SettingsListBox"
                     Grid.Row="1"
                     FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelFontSize}}"
                     FontWeight="400"
                     HorizontalContentAlignment="Stretch"
                     VerticalAlignment="Center"
                     Background="Transparent">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayItemPadding}}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid>
                                        <!-- SelectionBorder -->
                                        <Border x:Name="SelectionBorder"
                                                Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBorderMargin}}"
                                                BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBorderThickness}}"
                                                BorderBrush="Transparent"
                                                CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionCornerRadius}}">
                                            <Border x:Name="SelectionBackground"
                                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBackgroundMargin}}"
                                                    Background="Transparent"
                                                    CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBgCornerRadius}}"/>
                                        </Border>

                                        <!-- ItemBorder -->
                                        <Border x:Name="ItemBorder"
                                                Padding="{TemplateBinding Padding}"
                                                Background="Transparent">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- ItemDivider -->
                                        <Border x:Name="ItemDivider"
                                                Height="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayDividerHeight}}"
                                                VerticalAlignment="Bottom"
                                                Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayDividerMargin}}"
                                                Background="{DynamicResource DividerStrokeColorDefaultBrush}"
                                                SnapsToDevicePixels="True"/>
                                    </Grid>

                                    <ControlTemplate.Triggers>                                        
                                        
                                        <!-- Gradient BG -->
                                        <Trigger Property="Tag" Value="TreeContainer">
                                            <Setter TargetName="ItemBorder" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0"/>
                                                        <GradientStop Color="#20000000" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>

                                    </ControlTemplate.Triggers>

                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <!-- SettingsAutorunApp -->
                <ListBoxItem x:Name="SettingsAutorunApp" Tag="TreeHeader">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.05*"/>
                            <ColumnDefinition Width="0.80*"/>
                            <ColumnDefinition Width="0.10*"/>
                            <ColumnDefinition Width="0.05*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelMargin}}">
                            <TextBlock x:Name="SettingsAutorunAppLabel" 
                            Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelMargin}}"/>
                            <TextBlock x:Name="SettingsAutorunAppDesc"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayDescFontSize}}"/>
                        </StackPanel>

                        <Viewbox Grid.Column="2" 
                                Width="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                Height="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchHeight}}" 
                                Stretch="Uniform" HorizontalAlignment="Right">
                            <ui:ToggleSwitch x:Name="AutorunToggle"/>
                        </Viewbox>
                    </Grid>
                </ListBoxItem>

                <!-- Контейнер для горизонтальных субопций -->
                <ListBoxItem x:Name="TreeItemsContainer" 
                            Background="Transparent"
                            Tag="TreeContainer" 
                            Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayTreeItemsContainerMargin}}" 
                            Padding="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayTreeItemsContainerPadding}}">
                    <Grid>
                        <!-- <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions> -->

                        <ListBox x:Name="SubOptionsListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 Focusable="False">
                            
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3" Rows="1"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <!-- Стиль для дочерних элементов (1/3 ширины) -->
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <Border x:Name="SelectionBorder"
                                                            Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBorderMargin}}"
                                                            BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBorderThickness}}"
                                                            BorderBrush="Transparent"
                                                            CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionCornerRadius}}">
                                                        <Border x:Name="SelectionBackground"
                                                                Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBackgroundMargin}}"
                                                                Background="Transparent"
                                                                CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBgCornerRadius}}"/>
                                                    </Border>

                                                    <!-- TreeItemStyle -->
                                                    <Border x:Name="ItemBorder"
                                                            Padding="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayTreeItemsItemMargin}}"
                                                            Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayTreeItemsItemPadding}}"
                                                            CornerRadius="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlaySelectionBgCornerRadius}}"
                                                            BorderThickness="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayThickness}}"
                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                                        <ContentPresenter/>
                                                    </Border>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <!-- NoSplash -->
                            <ListBoxItem x:Name="NoSplash" Tag="TreeItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.10*"/>
                                        <ColumnDefinition Width="0.80*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="1"
                                    x:Name="SettingsTreeNoSplash"
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeMargin}}"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeFontSize}}"
                                    VerticalAlignment="Center"/>

                                    <Viewbox Grid.Column="2" 
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    VerticalAlignment="Center">
                                        <CheckBox x:Name="NoSplashToggle"/>
                                    </Viewbox>
                                </Grid>
                            </ListBoxItem>

                            <!-- NoMusic -->
                            <ListBoxItem x:Name="NoMusic" Tag="TreeItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.10*"/>
                                        <ColumnDefinition Width="0.80*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="1"
                                    x:Name="SettingsTreeNoMusic"
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeMargin}}"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeFontSize}}"
                                    VerticalAlignment="Center"/>

                                    <Viewbox Grid.Column="2" 
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    VerticalAlignment="Center">
                                        <CheckBox x:Name="NoMusicToggle"/>
                                    </Viewbox>
                                </Grid>
                            </ListBoxItem>

                            <!-- HotSwap -->
                            <ListBoxItem x:Name="HotSwap" Tag="TreeItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.10*"/>
                                        <ColumnDefinition Width="0.80*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                        <ColumnDefinition Width="0.05*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="1"
                                    x:Name="SettingsTreeHotSwap"
                                    Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeMargin}}"
                                    FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeFontSize}}"
                                    VerticalAlignment="Center"/>

                                    <Viewbox Grid.Column="2" 
                                    Width="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    Height="{DynamicResource {x:Static app:UiScaleKeys.ToggleSwitchWidth}}" 
                                    VerticalAlignment="Center">
                                        <CheckBox x:Name="HotSwapToggle"/>
                                    </Viewbox>
                                </Grid>
                            </ListBoxItem>
                        </ListBox>
                        
                    </Grid>
                </ListBoxItem>

                <!-- SettingsSourceDisplay -->
                <ListBoxItem x:Name="SettingsSourceDisplay">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.05*"/>
                            <ColumnDefinition Width="0.80*"/>
                            <ColumnDefinition Width="0.10*"/>
                            <ColumnDefinition Width="0.05*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelMargin}}">
                            <TextBlock x:Name="SettingsSourceDisplayLabel" 
                            Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelMargin}}"/>
                            <TextBlock x:Name="SettingsSourceDisplayDesc"
                                        Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayDescFontSize}}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" 
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Foreground="{DynamicResource ControlStrongStrokeColorDefaultBrush}" 
                        FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeFontSize}}"
                        FontFamily="Xbox Fluent">&#xE3B2;</TextBlock>
                    </Grid>
                </ListBoxItem>

                <!-- SettingsExitApp -->
                <ListBoxItem x:Name="SettingsExitApp" Tag="Last">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.05*"/>
                            <ColumnDefinition Width="0.90*"/>
                            <ColumnDefinition Width="0.05*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" 
                        x:Name="SettingsExitAppLabel" 
                        VerticalAlignment="Center"
                        Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayLabelTreeMargin}}"/>
                    </Grid>
                </ListBoxItem>

            </ListBox>

            <!-- AppInfo -->
            <TextBlock Grid.Row="2"
                       FontSize="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayDescFontSize}}"
                       Foreground="{DynamicResource TextFillColorDisabledBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="{DynamicResource {x:Static app:UiScaleKeys.SettingsOverlayAppInfoMargin}}">
                <Run Text="{x:Static app:AppInfo.Description}"/>
                <Run Text="v"/><Run Text="{x:Static app:AppInfo.Version}"/>
            </TextBlock>
            
        </Grid>
    </Border>
</UserControl>