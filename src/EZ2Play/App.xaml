            <!-- Style ListBoxItemStyle -->
            <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False">
                                <ContentPresenter Margin="0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style BaseItemStyle -->
            <Style x:Key="BaseItemStyle" TargetType="Rectangle">
                <Setter Property="Fill" Value="Transparent"/>
            </Style>

            <!-- Style HintTextStyle -->
            <Style x:Key="HintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource {x:Static app:UiScaleKeys.HintTextFontSize}}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="{DynamicResource {x:Static app:UiScaleKeys.HintTextMargin}}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="0"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style BotomCardStyle -->
            <Style x:Key="BotomCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
                <!-- <Setter Property="BorderBrush" Value="{StaticResource GradientBrush}"/> -->
                <Setter Property="BorderThickness" Value="{DynamicResource {x:Static app:UiScaleKeys.BaseCardThickness}}"/>
            </Style>

            <!-- Style BasicCardStyle -->
            <Style x:Key="BasicCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                <Setter Property="BorderThickness" Value="{DynamicResource {x:Static app:UiScaleKeys.BaseCardThickness}}"/>
            </Style>

            <!-- Style BasicCardTextStyle -->
            <Style x:Key="BasicCardTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="-1"/>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
