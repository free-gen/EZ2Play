<Application x:Class="EZ2Play.Main.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:app="clr-namespace:EZ2Play.App"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
                <ResourceDictionary Source="Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- TextBlock -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Manrope"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Icons -->
            <Style TargetType="Path">
                <Setter Property="Fill" Value="#E8E8E8"/>
            </Style>

            <!-- Style ListBoxItemStyle -->
            <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  ClipToBounds="False">
                                <ContentPresenter Margin="0"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Style BaseItemStyle -->
            <Style x:Key="BaseItemStyle" TargetType="Rectangle">
                <Setter Property="Fill" Value="Transparent"/>
            </Style>

            <!-- Style HintTextStyle -->
            <Style x:Key="HintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="FontSize" Value="{DynamicResource {x:Static app:UiScaleKeys.HintTextFontSize}}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="{DynamicResource {x:Static app:UiScaleKeys.HintTextMargin}}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="-1"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="HintCardStyle" TargetType="Border">
                <Setter Property="Background" Value="#F0151515"/>
            </Style>

            <!-- Style BasicCardStyle -->
            <Style x:Key="BasicCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource LayerFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                <Setter Property="BorderThickness" Value="{DynamicResource {x:Static app:UiScaleKeys.BaseCardThickness}}"/>
            </Style>

            <!-- Style="{StaticResource BasicCardTextStyle}" -->
            <Style x:Key="BasicCardTextStyle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="-1"/>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
