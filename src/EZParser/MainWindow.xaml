<ui:FluentWindow x:Class="EZParser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="EZParser" 
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ResizeMode="NoResize"
        MinWidth="900"
        MaxWidth="900"
        MinHeight="700"
        MaxHeight="700"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TitleBar -->
            <RowDefinition Height="Auto"/> <!-- TopBar -->
            <RowDefinition Height="1"/>    <!-- Divider Top -->
            <RowDefinition Height="*"/>    <!-- ScrollViewer -->
            <RowDefinition Height="1"/>    <!-- Divider Bottom -->
            <RowDefinition Height="Auto"/> <!-- BottomBar -->
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="EZParser" ShowMaximize="False"/>

        <!-- Top Bar -->
        <Grid Grid.Row="1" Margin="50,20,50,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <!-- <ColumnDefinition Width="200"/> -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="SourceCombo" 
                        Grid.Column="0" 
                        Height="36"  
                        HorizontalAlignment="Stretch">
                <ComboBoxItem Content="PsStore" IsSelected="True"/>
                <ComboBoxItem Content="GridDB"/>
            </ComboBox>

            <!-- <ui:PasswordBox x:Name="SteamGridDBApiKey" Grid.Column="1" Margin="10,0,0,0" PlaceholderText="API Key"/> -->
            
            <ui:AutoSuggestBox x:Name="SearchBox"
                        Grid.Column="2"
                        Margin="10,0,0,0"
                        PlaceholderText="Search game..."
                        Height="36"
                        TextChanged="SearchBox_TextChanged"
                        QuerySubmitted="SearchBox_QuerySubmitted"
                        SuggestionChosen="SearchBox_SuggestionChosen"/>

        </Grid>

        <Border Grid.Row="2"
        Height="1"
        Background="{ui:ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Scroll Area -->
        <Border Grid.Row="3"
        Background="{ui:ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer
                        x:Name="ScrollViewer"
                        VerticalScrollBarVisibility="Auto"
                        Background="Transparent">

                <ItemsControl x:Name="ResultsItemsControl"
                            HorizontalAlignment="Center"
                            Background="Transparent">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="0,30"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8"
                                    BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                                    Background="{ui:ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    Margin="5"
                                    Width="152">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Контейнер изображения -->
                                    <Grid Grid.Row="0">

                                        <!-- WPF-UI Image -->
                                        <ui:Image Source="{Binding ImageSource}"
                                                Width="150"
                                                Height="150"
                                                Stretch="UniformToFill"
                                                CornerRadius="8,8,0,0"
                                                HorizontalAlignment="Center"/>

                                        <!-- Чекбокс -->
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Bottom"
                                                Margin="5"
                                                Background="{ui:ThemeResource ControlOnImageFillColorDefaultBrush}"
                                                BorderBrush="{ui:ThemeResource ControlStrongStrokeColorDefaultBrush}"/>
                                    </Grid>

                                    <!-- Текст -->
                                    <TextBlock Grid.Row="1"
                                            Text="{Binding Name}"
                                            TextWrapping="Wrap"
                                            Margin="8,5,8,8"
                                            MaxHeight="40"
                                            Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}"/>
                                </Grid>

                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>
        </Border>

        <ui:ContentDialogHost Grid.Row="3" x:Name="RootContentDialogHost" />

        <Border Grid.Row="4"
        Height="1"
        Background="{ui:ThemeResource DividerStrokeColorDefaultBrush}"/>

        <!-- Bottom Bar -->
        <Grid Grid.Row="5" Margin="50,30">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ComboBox x:Name="FormatCombo" Height="36" Width="100" Margin="0,0,10,0">
                    <ComboBoxItem Content="ICO" IsSelected="True"/>
                    <ComboBoxItem Content="PNG"/>
                </ComboBox>
                <Button x:Name="DownloadSelectedBtn" Content="Download selected" Height="36" Margin="0,0,10,0" Click="DownloadSelected_Click"/>
                <Button x:Name="DownloadAllBtn" Content="Download all" Height="36" Margin="0,0,10,0" Click="DownloadAll_Click"/>
                <Button x:Name="ClearBtn" Content="Clear selected" Height="36" Margin="0,0,10,0" Click="Clear_Click"/>
            </StackPanel>
            
            <TextBlock Grid.Column="1" x:Name="StatusLabel" Text="Ready" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

    </Grid>

</ui:FluentWindow>
